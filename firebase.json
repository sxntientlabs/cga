{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "ipdbrilian",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "build_site.py"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/aiTutor",
        "function": {
          "functionId": "aiTutor",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
